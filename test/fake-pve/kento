#!/usr/bin/env bash
# Fake `kento` (the seadog guest realizer) for the pseudo-soak. Implements
# the one subcommand RealKento::provision invokes:
#   kento create --vmid <v> --mode <lxc|vm> --image-ref <ref> --name <n>
#                --mac <m> --ip <ip>
# It adds a guest row (with realistic hardware/fingerprint defaults) to the
# shared JSON guest table. RealKento then stamps the seadog markers via the
# subsequent `qm set`/`pct set`. State + helpers live in _lib.sh.

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$(readlink -f "${BASH_SOURCE[0]}")")" && pwd)"
# shellcheck source=/dev/null
. "${SCRIPT_DIR}/_lib.sh"

sub="${1:-}"
shift || true

case "$sub" in
  create)
    quorum_guard
    vmid=""
    mode=""
    name=""
    mac=""
    while [ "$#" -gt 0 ]; do
      case "$1" in
        --vmid) vmid="$2"; shift 2 ;;
        --mode) mode="$2"; shift 2 ;;
        --image-ref) shift 2 ;;
        --name) name="$2"; shift 2 ;;
        --mac) mac="$2"; shift 2 ;;
        --ip) shift 2 ;;
        *) shift ;;
      esac
    done
    if [ -z "$vmid" ] || [ -z "$mode" ]; then
      printf 'kento create: missing --vmid/--mode\n' >&2
      exit 2
    fi
    if guest_exists "$vmid"; then
      printf 'kento create: vmid %s already exists\n' "$vmid" >&2
      exit 2
    fi
    if [ "$mode" = "lxc" ]; then
      upsert_guest "$vmid" lxc "name=$name" "mac=$mac" bridge=vmbr0 model=veth machine= bios= scsihw= memory=1024 cores=2 disk_geometry=local:"$vmid"/vm-"$vmid"-disk-0.raw disk_size=$((8 * 1024 * 1024 * 1024))
    else
      upsert_guest "$vmid" vm "name=$name" "mac=$mac" bridge=vmbr0 model=virtio machine=q35 bios=seabios scsihw=virtio-scsi-pci memory=2048 cores=2 disk_geometry=local-lvm:vm-"$vmid"-disk-0 disk_size=$((20 * 1024 * 1024 * 1024))
    fi
    printf '{"ok":true,"vmid":%s,"mode":"%s"}\n' "$vmid" "$mode"
    ;;
  *)
    printf 'fake kento: unsupported subcommand %s\n' "$sub" >&2
    exit 2
    ;;
esac
